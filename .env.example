# ── App ─────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-app.railway.app

# ── Database ─────────────────────────────────────────────────────
# Railway PostgreSQL (Railway injects DATABASE_URL automatically)
# Leave DB_CONNECTION=sqlite for local development
DB_CONNECTION=sqlite
DB_DATABASE=/app/database/aivo.sqlite

# For Railway PostgreSQL — Railway sets DATABASE_URL automatically.
# When DATABASE_URL is set, the app uses it instead of the above.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Stripe ───────────────────────────────────────────────────────
# Secret key — NEVER commit this to git
STRIPE_SECRET_KEY=sk_live_...

# Webhook signing secret — get from Stripe Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — from Stripe Dashboard → Product catalogue
STRIPE_PRICE_GROWTH=price_1TEv26023O8YaRMl19sz7I0I
STRIPE_PRICE_PRO=price_1TEv5m023O8YaRMlNSKCQGfs
STRIPE_PRICE_AGENCY=price_1TEv7E023O8YaRMlWipseVgw

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Use * for development, set exact domain(s) for production
ALLOWED_ORIGINS=*
