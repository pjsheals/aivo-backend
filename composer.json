{
    "name": "aivo/optimize-backend",
    "description": "AIVO Optimize Backend API",
    "type": "project",
    "require": {
        "php": "^8.2",
        "stripe/stripe-php": "^13.0",
        "vlucas/phpdotenv": "^5.6",
        "illuminate/database": "^11.0",
        "illuminate/events": "^11.0",
        "illuminate/pagination": "^11.0",
        "dompdf/dompdf": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Aivo\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php artisan migrate --force || true"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
